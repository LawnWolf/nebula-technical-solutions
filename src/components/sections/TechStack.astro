---
const techStack = [
  'Astro', 'React', 'Node.js', 'TypeScript', 'PostgreSQL',
  'Redis', 'Docker', 'Kubernetes', 'Terraform', 'AWS',
  'Linux', 'Nginx', 'Go', 'Python', 'Tailwind CSS',
];
---

<section id="tech-stack" aria-label="Technology stack" class="tech-section">
  <div class="fade-in section-label">
    <p>// OUR TECH STACK</p>
  </div>

  <div class="marquee-wrap">
    <div class="fade-edge fade-edge--left"></div>
    <div class="fade-edge fade-edge--right"></div>

    <div class="overflow-clip">
      <div class="marquee-track" aria-hidden="true">
        {[...techStack, ...techStack].map((tech) => (
          <span class="tech-pill">{tech}</span>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .tech-section {
    padding: 80px 0;
    background: var(--bg-surface);
    overflow: hidden;
    border-top: 1px solid var(--border-subtle);
    border-bottom: 1px solid var(--border-subtle);
  }

  .section-label {
    text-align: center;
    margin-bottom: 40px;
    padding: 0 24px;
  }

  .section-label p {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
  }

  .marquee-wrap {
    position: relative;
  }

  .fade-edge {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 120px;
    z-index: 2;
    pointer-events: none;
  }

  .fade-edge--left {
    left: 0;
    background: linear-gradient(to right, var(--bg-surface), transparent);
  }

  .fade-edge--right {
    right: 0;
    background: linear-gradient(to left, var(--bg-surface), transparent);
  }

  .overflow-clip {
    overflow: hidden;
  }

  .tech-pill {
    display: inline-flex;
    align-items: center;
    margin: 0 12px;
    padding: 8px 20px;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 100px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    color: var(--text-primary);
    white-space: nowrap;
    backdrop-filter: blur(8px);
  }
</style>
