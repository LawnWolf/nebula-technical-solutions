---
---

<section id="cta" aria-label="Call to action" class="nebula-bg cta-section">
  <div class="cta-inner">
    <div class="fade-in">
      <p class="eyebrow">// LET'S BUILD</p>
      <h2>
        Ready to Build Something
        <span class="gradient-text"> Extraordinary?</span>
      </h2>
      <p class="subtext">
        Whether it's a landing page or a planet-scale platform — we're ready.
      </p>
      <a href="#contact" class="btn-primary cta-btn">
        Launch Your Project →
      </a>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding: 120px 24px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .cta-inner {
    position: relative;
    z-index: 1;
    max-width: 700px;
    margin: 0 auto;
  }

  .eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: var(--accent-cyan);
    letter-spacing: 0.1em;
    margin-bottom: 20px;
  }

  h2 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin-bottom: 20px;
    letter-spacing: -0.03em;
  }

  .subtext {
    color: var(--text-muted);
    font-size: 1.05rem;
    margin-bottom: 40px;
    line-height: 1.7;
  }

  .cta-btn {
    font-size: 1.1rem;
    padding: 16px 36px;
  }
</style>
